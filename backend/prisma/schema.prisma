// PAYROLL MODELS



// =========================



model Employee {



  id                     String                   @id @default(cuid())



  schoolId               String



  employeeNumber         String?



  firstName              String



  lastName               String



  fullName               String?



  idNumber               String?



  dateOfBirth            DateTime?



  gender                 String?



  mobileNumber           String?



  email                  String?



  physicalAddress        String?                  @db.Text



  jobTitle               String?



  department             String?



  employmentType         EmploymentType           @default(PERMANENT)



  salaryType             SalaryType               @default(MONTHLY)



  payFrequency           PayFrequency             @default(MONTHLY)



  paymentMethod          String?



  startDate              DateTime?



  endDate                DateTime?



  isActive               Boolean                  @default(true)



  taxNumber              String?



  uifApplicable          Boolean                  @default(true)



  incomeTaxApplicable    Boolean                  @default(true)



  basicSalary            Decimal                  @default(0) @db.Decimal(12, 2)



  hourlyRate             Decimal                  @default(0) @db.Decimal(12, 2)

  overtimeRate           Decimal                  @default(0) @db.Decimal(12, 2)

  overtimeHours          Decimal                  @default(0) @db.Decimal(12, 2)

  fixedHousingAllowance  Decimal                  @default(0) @db.Decimal(12, 2)



  fixedTransportAllowance Decimal                 @default(0) @db.Decimal(12, 2)



  fixedCellphoneAllowance Decimal                 @default(0) @db.Decimal(12, 2)



  fixedOtherAllowance    Decimal                  @default(0) @db.Decimal(12, 2)



  fixedPension           Decimal                  @default(0) @db.Decimal(12, 2)



  fixedMedicalAid        Decimal                  @default(0) @db.Decimal(12, 2)



  fixedStaffLoan         Decimal                  @default(0) @db.Decimal(12, 2)



  fixedStaffAdvance      Decimal                  @default(0) @db.Decimal(12, 2)



  fixedOtherDeduction    Decimal                  @default(0) @db.Decimal(12, 2)

  employeeMedicalAid     Decimal                  @default(0) @db.Decimal(12, 2)

  employerMedicalAid     Decimal                  @default(0) @db.Decimal(12, 2)

  employeePension        Decimal                  @default(0) @db.Decimal(12, 2)

  employerPension        Decimal                  @default(0) @db.Decimal(12, 2)


  bankAccountHolder      String?



  bankName               String?



  bankAccountNumber      String?



  bankBranchCode         String?



  payslipDeliveryPreference PayslipDeliveryPreference @default(BOTH)



  sendPayslipByEmail     Boolean                  @default(true)



  notes                  String?                  @db.Text



  createdAt              DateTime                 @default(now())



  updatedAt              DateTime                 @updatedAt



  school                 School                   @relation(fields: [schoolId], references: [id], onDelete: Cascade)



  payrollRunEmployees    PayrollRunEmployee[]



  payslips               Payslip[]



  @@index([schoolId])



  @@index([employeeNumber])



  @@index([email])



  @@index([isActive])



}



model PayrollSetting {



  id                           String         @id @default(cuid())



  schoolId                     String



  taxYear                      Int



  isActive                     Boolean        @default(true)



  payFrequency                 PayFrequency   @default(MONTHLY)



  defaultPayDay                Int?



  currency                     String         @default("ZAR")



  // SARS / UIF settings



  primaryRebate                Decimal        @default(0) @db.Decimal(12, 2)



  secondaryRebate              Decimal        @default(0) @db.Decimal(12, 2)



  tertiaryRebate               Decimal        @default(0) @db.Decimal(12, 2)



  taxThresholdUnder65          Decimal        @default(0) @db.Decimal(12, 2)



  taxThreshold65To74           Decimal        @default(0) @db.Decimal(12, 2)



  taxThreshold75AndOver        Decimal        @default(0) @db.Decimal(12, 2)



  uifEnabled                   Boolean        @default(true)



  uifEmployeePercent           Decimal        @default(1) @db.Decimal(5, 2)



  uifEmployerPercent           Decimal        @default(1) @db.Decimal(5, 2)



  uifMonthlyCeiling            Decimal        @default(17712) @db.Decimal(12, 2)



  payslipPrefix                String?        @default("PS")



  payrollRunPrefix             String?        @default("PR")



  payrollEmailFromName         String?



  payrollEmailReplyTo          String?



  payslipEmailSubjectTemplate  String?        @db.Text



  payslipEmailBodyTemplate     String?        @db.Text



  bookkeeperName               String?



  bookkeeperEmail              String?



  bookkeeperSendPdf            Boolean        @default(true)



  bookkeeperSendExcel          Boolean        @default(true)



  bookkeeperEmailSubjectTemplate String?      @db.Text



  bookkeeperEmailBodyTemplate  String?        @db.Text



  envelopeTopOffsetMm          Decimal        @default(0) @db.Decimal(8, 2)



  envelopeLeftOffsetMm         Decimal        @default(0) @db.Decimal(8, 2)



  showFoldGuide                Boolean        @default(false)



  createdAt                    DateTime       @default(now())



  updatedAt                    DateTime       @updatedAt



  school                       School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)



  payrollRuns                  PayrollRun[]



  @@unique([schoolId, taxYear])



  @@index([schoolId])



  @@index([taxYear])



}



model PayrollRun {



  id                    String              @id @default(cuid())



  schoolId              String



  payrollSettingId      String?



  runNumber             String?



  taxYear               Int



  payrollMonth          Int



  payrollYear           Int



  payDate               DateTime



  status                PayrollRunStatus    @default(DRAFT)



  employeeCount         Int                 @default(0)



  grossTotal            Decimal             @default(0) @db.Decimal(14, 2)



  deductionsTotal       Decimal             @default(0) @db.Decimal(14, 2)



  netTotal              Decimal             @default(0) @db.Decimal(14, 2)



  employerCostTotal     Decimal             @default(0) @db.Decimal(14, 2)



  finalizedAt           DateTime?



  notes                 String?             @db.Text



  createdAt             DateTime            @default(now())



  updatedAt             DateTime            @updatedAt



  school                School              @relation(fields: [schoolId], references: [id], onDelete: Cascade)



