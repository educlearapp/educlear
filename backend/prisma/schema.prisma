generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"

  url = env("DATABASE_URL")
}


enum FeeFrequency {

  MONTHLY

  ONCE_OFF

  YEARLY

}
enum UserRole {
  SCHOOL_ADMIN

  FINANCE

  STAFF
}

model School {
  id String @id @default(cuid())

  name String

  email String? @unique

  phone String?

  createdAt DateTime @default(now())

  users User[]
  roles SchoolRole[]

  parents Parent[]

  learners Learner[]
  familyAccounts FamilyAccount[]
  fees FeeStructure[]
  SchoolFeeSetting SchoolFeeSetting[]
  LetterTemplate   LetterTemplate[]
  Letter           Letter[]

  teacherPerformances TeacherPerformance[]
}
  


model FeeStructure {

  id        String       @id @default(cuid())

  schoolId  String

  name      String

  amount    Float

  frequency FeeFrequency

  grade     String?

  createdAt DateTime     @default(now())



  school    School       @relation(fields: [schoolId], references: [id])



  @@index([schoolId])

}

model User {
  id String @id @default(cuid())

  schoolId String

  email String

  passwordHash String

  isActive Boolean @default(true)

  /// RBAC role assignment (preferred). Kept optional for backward compatibility.
  roleId String?

  role UserRole @default(SCHOOL_ADMIN)

  createdAt DateTime @default(now())

  school School @relation(fields: [schoolId], references: [id])

  roleRef SchoolRole? @relation(fields: [roleId], references: [id], onDelete: SetNull)

  permissionOverrides UserPermissionOverride[]

  @@unique([schoolId, email])
  @@index([schoolId])
  @@index([roleId])
}

/// Global permission catalog (keys are stable across schools)
model Permission {
  id String @id @default(cuid())

  key String @unique

  label String

  description String?

  category String?

  rolePermissions RolePermission[]
  userOverrides UserPermissionOverride[]
}

/// Role definitions are per-school
model SchoolRole {
  id String @id @default(cuid())

  schoolId String

  name String

  /// Owner role effectively implies all permissions.
  isOwner Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  users User[]
  permissions RolePermission[]

  @@unique([schoolId, name])
  @@index([schoolId])
}

model RolePermission {
  id String @id @default(cuid())

  roleId String
  permissionId String

  role SchoolRole @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

/// Optional per-user overrides (allow/deny). When present, overrides role permissions.
model UserPermissionOverride {
  id String @id @default(cuid())

  userId String
  permissionId String

  allowed Boolean

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionId])
  @@index([userId])
  @@index([permissionId])
}

model Parent {

  id String @id @default(cuid())



  schoolId String
familyAccountId String?


  relationship String?

  title String?

  firstName String

  surname String

  nickname String?

  idNumber String? @unique 
  status String @default("GREEN")

  outstandingAmount Float @default(0)

  maritalStatus String?

  notes String?



  homeNo String?

  workNo String?

  cellNo String

  faxNo String?

  email String?



  communicationByEmail Boolean @default(true)

  communicationByPrint Boolean @default(true)

  communicationBySMS Boolean @default(true)



  createdAt DateTime @default(now())



  school School @relation(fields: [schoolId], references: [id])
familyAccount FamilyAccount? @relation(fields: [familyAccountId], references: [id])


  links ParentLearnerLink[]

  Letter Letter[]



  @@index([schoolId])

  @@index([schoolId, cellNo])


}
model FamilyAccount {

  id              String    @id @default(cuid())

  schoolId        String

  accountRef      String    @unique

  familyName      String

  createdAt       DateTime  @default(now())



  school          School    @relation(fields: [schoolId], references: [id])

  learners        Learner[]

  parents         Parent[]



  @@index([schoolId])

  @@index([schoolId, familyName])

}

model Learner {
  id String @id @default(cuid())

  schoolId String
  familyAccountId String?
  firstName String

  lastName String

  birthDate DateTime?
  gender String?
  idNumber String?

  grade String

  className String?

  admissionNo String?
  tuitionFee   Float   @default(0)

transportFee Float   @default(0)

otherFee     Float   @default(0)

totalFee     Float   @default(0)

  createdAt DateTime @default(now())

  school School @relation(fields: [schoolId], references: [id])
familyAccount FamilyAccount? @relation(fields: [familyAccountId], references: [id])
  links ParentLearnerLink[]

  Letter Letter[]

  @@unique([schoolId, admissionNo])
  @@index([schoolId])
  @@index([schoolId, grade])
  
}



model ParentLearnerLink {
  id String @id @default(cuid())

  schoolId String

  parentId String

  learnerId String

  relation String?

  isPrimary Boolean @default(true)

  parent Parent @relation(fields: [parentId], references: [id])

  learner Learner @relation(fields: [learnerId], references: [id])

  @@unique([parentId, learnerId])
  @@index([schoolId])
}

enum LetterType {
  DEMAND

  SECTION_41
}

enum LetterStatus {
  DRAFT

  GENERATED

  SENT
}

model SchoolFeeSetting {
  id String @id @default(cuid())

  schoolId String

  grade String

  monthlyFeeCents Int

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  school School @relation(fields: [schoolId], references: [id])

  @@unique([schoolId, grade])
  @@index([schoolId])
}

model CompetitorSchool {
  id String @id @default(cuid())

  name String

  province String?

  city String?

  createdAt DateTime @default(now())

  fees CompetitorFee[]
}

model CompetitorFee {
  id String @id @default(cuid())

  competitorSchoolId String

  grade String

  monthlyFeeCents Int

  createdAt DateTime @default(now())

  competitorSchool CompetitorSchool @relation(fields: [competitorSchoolId], references: [id])

  @@index([competitorSchoolId])
  @@index([grade])
}

model LetterTemplate {
  id String @id @default(cuid())

  schoolId String

  type LetterType

  name String

  subject String

  body String

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  school School @relation(fields: [schoolId], references: [id])

  @@index([schoolId, type])
}

model Letter {
  id String @id @default(cuid())

  schoolId String

  type LetterType

  status LetterStatus @default(DRAFT)

  parentId String

  learnerId String?

  amountCents Int?

  dueDate DateTime?

  subject String

  body String

  createdAt DateTime @default(now())

  sentAt DateTime?

  school School @relation(fields: [schoolId], references: [id])

  parent Parent @relation(fields: [parentId], references: [id])

  learner Learner? @relation(fields: [learnerId], references: [id])

  @@index([schoolId, type])
  @@index([parentId])
}
model TeacherPerformance {

  id                   String   @id @default(cuid())

  schoolId             String

  teacherName          String

  teacherEmail         String?

  month                String

  learnerResults       Float

  classroomManagement  Float

  teachingQuality      Float

  administration       Float

  professionalConduct  Float

  finalScore           Float

  performanceLevel     String

  notes                String?

  createdAt            DateTime @default(now())

  updatedAt            DateTime @updatedAt



  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)



  @@index([schoolId])

  @@index([month])

}