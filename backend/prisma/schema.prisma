  PERMANENT



  TEMPORARY



  CONTRACT



  PART_TIME



  CASUAL



}



enum SalaryType {



  MONTHLY



  WEEKLY



  DAILY



  HOURLY



}



enum PayFrequency {



  MONTHLY



  WEEKLY



  FORTNIGHTLY



}



enum PayrollRunStatus {



  DRAFT



  FINALIZED



  CANCELLED



}



enum PayrollItemType {



  EARNING



  DEDUCTION



  EMPLOYER_CONTRIBUTION



}



