generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"

  url = env("DATABASE_URL")
}


enum FeeFrequency {

  MONTHLY

  MONTHLY_EXCL_DEC

  MONTHLY_EXCL_NOV_DEC

  ONCE_OFF

  ANNUALLY

  YEARLY

  TERMLY

  DAILY

}

enum FeeCategory {
  SCHOOL_CHARGE
  EXTRAMURAL_CHARGE
}
enum UserRole {
  SCHOOL_ADMIN

  FINANCE

  STAFF
}

/// ACTIVE = on current class lists; HISTORICAL = billing/ledger only (unenrolled).
enum LearnerEnrollmentStatus {
  ACTIVE
  HISTORICAL
}

model School {
  id String @id @default(cuid())

  name String

  email String? @unique

  phone String?

  /// Mobile / cell contact number (separate from landline `phone`).
  cellNo String?

  /// Physical address lines for correspondence and payslips (newline-separated).
  address String?

  /// Postal address when different from physical (newline-separated lines).
  postalAddress String?

  /// Banking details for invoices/statements (newline-separated lines).
  bankingDetails String?

  /// Optional logo image URL for payslips and branding (HTTPS recommended).
  logoUrl String?

  /// Optional brand color for PDFs and UI (e.g. #1a2b3c or #36a).
  primaryColor String?

  createdAt DateTime @default(now())

  users User[]
  roles SchoolRole[]

  parents Parent[]

  learners Learner[]
  learnerResults LearnerResult[]



learnerReports LearnerReport[]


  familyAccounts FamilyAccount[]
  fees FeeStructure[]
  SchoolFeeSetting SchoolFeeSetting[]
  LetterTemplate   LetterTemplate[]
  Letter           Letter[]

  teacherPerformances TeacherPerformance[]
  employees        Employee[]



  payrollSettings  PayrollSetting[]



  payrollRuns      PayrollRun[]



  payslips         Payslip[]



  payrollEmailLogs PayrollEmailLog[]

  billingSettings BillingSettings?
  billingDeposits BillingDeposit[]
  bankStatementImports BankStatementImport[]
  bankTransactions BankTransaction[]
  suppliers Supplier[]
  supplierInvoices SupplierInvoice[]
  expenseCategories ExpenseCategory[]
  accountingJournals AccountingJournal[]
  classrooms Classroom[]
  parentNotifications ParentNotification[]
  parentTeacherThreads ParentTeacherThread[]
  homeworkPosts HomeworkPost[]
  schoolNotices SchoolNotice[]
  parentDocuments ParentDocument[]
  learnerIncidents LearnerIncident[]
  learnerAttendances LearnerAttendance[]
  learnerBillingPlanLines LearnerBillingPlanLine[]
  parentOnboardings ParentOnboarding[]
  parentOutreachQueue ParentOutreachQueue[]
  communicationMessages CommunicationMessage[]
  communicationCampaigns CommunicationCampaign[]
  communicationTemplates CommunicationTemplate[]
  communicationLogs CommunicationLog[]
  pushSubscriptions PushSubscription[]
  schoolCommunicationProfile SchoolCommunicationProfile?
  schoolEmailSettings SchoolEmailSettings?
  schoolSubscription SchoolSubscription?
  subscriptionInvoices SubscriptionInvoice[]
  subscriptionPaymentLogs SubscriptionPaymentLog[]
  creditPurchaseInvoices CreditPurchaseInvoice[]
  creditPurchasePaymentLogs CreditPurchasePaymentLog[]
}

enum EduClearPackageCode {
  STARTER
  UNLIMITED
}

enum SchoolSubscriptionStatus {
  PENDING_PAYMENT
  ACTIVE
  PAST_DUE
  CANCELLED
  SUSPENDED
}

enum SubscriptionInvoiceStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
}

enum SubscriptionPaymentStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
}

enum PaymentGatewayProvider {
  PAYFAST
  OZOW
}

model EduClearPackage {
  id                  String              @id @default(cuid())
  code                EduClearPackageCode @unique
  name                String
  monthlyPriceCents   Int
  learnerLimit        Int?
  payrollStaffLimit   Int?
  mostPopular         Boolean             @default(false)
  description         String?
  isActive            Boolean             @default(true)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  subscriptions SchoolSubscription[]
}

model SchoolSubscription {
  id                 String                   @id @default(cuid())
  schoolId           String                   @unique
  packageId          String
  packageCode        EduClearPackageCode
  status             SchoolSubscriptionStatus @default(PENDING_PAYMENT)
  activationSource   String?
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  activatedAt        DateTime?
  cancelledAt        DateTime?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt

  school   School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  package  EduClearPackage @relation(fields: [packageId], references: [id], onDelete: Restrict)
  invoices SubscriptionInvoice[]

  @@index([status])
  @@index([packageCode])
}

model SubscriptionInvoice {
  id             String                    @id @default(cuid())
  schoolId       String
  subscriptionId String
  invoiceNumber  String
  amountCents    Int
  currency       String                    @default("ZAR")
  status         SubscriptionInvoiceStatus @default(PENDING)
  periodStart    DateTime?
  periodEnd      DateTime?
  dueAt          DateTime
  paidAt         DateTime?
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt

  school       School               @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  subscription SchoolSubscription   @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  payments     SubscriptionPaymentLog[]

  @@unique([invoiceNumber])
  @@index([schoolId, status])
  @@index([subscriptionId])
}

model SubscriptionPaymentLog {
  id                String                    @id @default(cuid())
  schoolId          String
  invoiceId         String
  gateway           PaymentGatewayProvider    @default(PAYFAST)
  status            SubscriptionPaymentStatus @default(PENDING)
  merchantPaymentId String
  gatewayPaymentId  String?
  amountCents       Int
  checkoutUrl       String?
  returnUrl         String?
  cancelUrl         String?
  notifyUrl         String?
  payerEmail        String?
  rawRequest        Json?
  rawNotify         Json?
  failureReason     String?
  paidAt            DateTime?
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt

  school  School              @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  invoice SubscriptionInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([schoolId, createdAt])
  @@index([invoiceId])
  @@index([merchantPaymentId])
  @@index([status])
}

enum EduClearCreditBundleCode {
  FOUNDATION
  GROWTH
  PROFESSIONAL
  ELITE
}

enum CreditPurchaseInvoiceStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
}

enum CreditPurchasePaymentStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
}

model EduClearCreditBundle {
  id          String                   @id @default(cuid())
  code        EduClearCreditBundleCode @unique
  name        String
  smsCredits  Int
  priceCents  Int
  mostPopular Boolean                  @default(false)
  description String?
  isActive    Boolean                  @default(true)
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt

  invoices CreditPurchaseInvoice[]
}

model CreditPurchaseInvoice {
  id               String                      @id @default(cuid())
  schoolId         String
  bundleId         String
  bundleCode       EduClearCreditBundleCode
  invoiceNumber    String
  amountCents      Int
  smsCredits       Int
  currency         String                      @default("ZAR")
  status           CreditPurchaseInvoiceStatus @default(PENDING)
  creditsGrantedAt DateTime?
  paidAt           DateTime?
  createdAt        DateTime                    @default(now())
  updatedAt        DateTime                    @updatedAt

  school   School               @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  bundle   EduClearCreditBundle @relation(fields: [bundleId], references: [id], onDelete: Restrict)
  payments CreditPurchasePaymentLog[]

  @@unique([invoiceNumber])
  @@index([schoolId, status])
  @@index([bundleCode])
}

model CreditPurchasePaymentLog {
  id                String                      @id @default(cuid())
  schoolId          String
  invoiceId         String
  gateway           PaymentGatewayProvider      @default(PAYFAST)
  status            CreditPurchasePaymentStatus @default(PENDING)
  merchantPaymentId String
  gatewayPaymentId  String?
  amountCents       Int
  checkoutUrl       String?
  returnUrl         String?
  cancelUrl         String?
  notifyUrl         String?
  payerEmail        String?
  rawRequest        Json?
  rawNotify         Json?
  failureReason     String?
  paidAt            DateTime?
  createdAt         DateTime                    @default(now())
  updatedAt         DateTime                    @updatedAt

  school  School                @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  invoice CreditPurchaseInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([schoolId, createdAt])
  @@index([invoiceId])
  @@index([merchantPaymentId])
  @@index([status])
}

enum BankTransactionMatchStatus {
  imported
  suggested
  matched
  unmatched
  duplicate
  ready_to_post
  accepted
  rejected
}

model BillingSettings {
  id String @id @default(cuid())

  schoolId String @unique

  settings Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
}
  


model FeeStructure {

  id        String       @id @default(cuid())

  schoolId  String

  /// Legacy fields (kept for existing billing UI compatibility)
  name      String

  amount    Float

  frequency FeeFrequency

  /// Fees module fields
  category  FeeCategory?
  type      String?
  description String?

  notes     String?

  grade     String?

  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  isActive  Boolean      @default(true)



  school    School       @relation(fields: [schoolId], references: [id])



  @@index([schoolId])
  @@index([schoolId, isActive])

}

model User {
  id String @id @default(cuid())

  schoolId String

  email String
  fullName String?
  passwordHash String

  isActive Boolean @default(true)

  /// RBAC role assignment (preferred). Kept optional for backward compatibility.
  roleId String?

  role UserRole @default(SCHOOL_ADMIN)

  createdAt DateTime @default(now())

  school School @relation(fields: [schoolId], references: [id])

  roleRef SchoolRole? @relation(fields: [roleId], references: [id], onDelete: SetNull)

  permissionOverrides UserPermissionOverride[]

  @@unique([schoolId, email])
  @@index([schoolId])
  @@index([roleId])
}

/// Global permission catalog (keys are stable across schools)
model Permission {
  id String @id @default(cuid())

  key String @unique

  label String

  description String?

  category String?

  rolePermissions RolePermission[]
  userOverrides UserPermissionOverride[]
}

/// Role definitions are per-school
model SchoolRole {
  id String @id @default(cuid())

  schoolId String

  name String

  /// Owner role effectively implies all permissions.
  isOwner Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  users User[]
  permissions RolePermission[]

  @@unique([schoolId, name])
  @@index([schoolId])
}

model RolePermission {
  id String @id @default(cuid())

  roleId String
  permissionId String

  role SchoolRole @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

/// Optional per-user overrides (allow/deny). When present, overrides role permissions.
model UserPermissionOverride {
  id String @id @default(cuid())

  userId String
  permissionId String

  allowed Boolean

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionId])
  @@index([userId])
  @@index([permissionId])
}

model Parent {

  id String @id @default(cuid())



  schoolId String
familyAccountId String?


  relationship String?

  title String?

  firstName String

  surname String

  nickname String?

  idNumber String? @unique 
  status String @default("GREEN")

  outstandingAmount Float @default(0)

  maritalStatus String?

  employer String?

  notes String?

  homeAddress String?

  homeNo String?

  workNo String?

  cellNo String

  faxNo String?

  email String?

  communicationAdministration Boolean @default(true)

  communicationBilling Boolean @default(true)

  communicationByEmail Boolean @default(true)

  communicationByPrint Boolean @default(true)

  communicationBySMS Boolean @default(true)



  createdAt DateTime @default(now())



  school School @relation(fields: [schoolId], references: [id])
familyAccount FamilyAccount? @relation(fields: [familyAccountId], references: [id])


  links ParentLearnerLink[]

  Letter Letter[]
  notifications ParentNotification[]
  teacherThreads ParentTeacherThread[]
  onboarding ParentOnboarding?
  outreachQueue ParentOutreachQueue[]
  communicationMessages CommunicationMessage[]
  pushSubscriptions PushSubscription[]

  @@index([schoolId])

  @@index([schoolId, cellNo])


}
model FamilyAccount {

  id              String    @id @default(cuid())

  schoolId        String

  accountRef      String    @unique

  familyName      String

  createdAt       DateTime  @default(now())



  school          School    @relation(fields: [schoolId], references: [id])

  learners        Learner[]

  parents         Parent[]

  billingDeposits BillingDeposit[]



  @@index([schoolId])

  @@index([schoolId, familyName])

}

model Learner {
  id String @id @default(cuid())

  schoolId String
  familyAccountId String?
  firstName String

  lastName String

  nickname String?

  birthDate DateTime?
  gender String?
  idNumber String?
  homeLanguage String?
  citizenship String?

  grade String

  className String?

  enrollmentStatus LearnerEnrollmentStatus @default(ACTIVE)

  admissionNo String?
  tuitionFee   Float   @default(0)

transportFee Float   @default(0)

otherFee     Float   @default(0)

totalFee     Float   @default(0)

  createdAt DateTime @default(now())

  notes String?

  school School @relation(fields: [schoolId], references: [id])
familyAccount FamilyAccount? @relation(fields: [familyAccountId], references: [id])
  links ParentLearnerLink[]

  Letter Letter[]
  results LearnerResult[]



reports LearnerReport[]

  billingDeposits BillingDeposit[]
  billingPlanLines LearnerBillingPlanLine[]
  notifications ParentNotification[]
  teacherThreads ParentTeacherThread[]
  homeworkPosts HomeworkPost[]
  incidents LearnerIncident[]
  attendances LearnerAttendance[]
  communicationMessages CommunicationMessage[]

  @@unique([schoolId, admissionNo])
  @@index([schoolId])
  @@index([schoolId, grade])
  @@index([schoolId, enrollmentStatus])

}

/// Persistent per-learner billing plan fee lines (DB source of truth; replaces ephemeral JSON on Render).
model LearnerBillingPlanLine {
  id             String   @id @default(cuid())
  schoolId       String
  learnerId      String
  feeDescription String
  amount         Float
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  school  School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  learner Learner @relation(fields: [learnerId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([schoolId, learnerId])
}

model ParentLearnerLink {
  id String @id @default(cuid())

  schoolId String

  parentId String

  learnerId String

  relation String?

  isPrimary Boolean @default(true)

  isPayingPerson Boolean @default(false)

  billingStatement Boolean @default(true)

  billingInvoice Boolean @default(true)

  billingReceipt Boolean @default(true)

  parent Parent @relation(fields: [parentId], references: [id])

  learner Learner @relation(fields: [learnerId], references: [id])

  @@unique([parentId, learnerId])
  @@index([schoolId])
}

enum LetterType {
  DEMAND

  SECTION_41
}

enum LetterStatus {
  DRAFT

  GENERATED

  SENT
}

model SchoolFeeSetting {
  id String @id @default(cuid())

  schoolId String

  grade String

  monthlyFeeCents Int

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  school School @relation(fields: [schoolId], references: [id])

  @@unique([schoolId, grade])
  @@index([schoolId])
}

model CompetitorSchool {
  id String @id @default(cuid())

  name String

  province String?

  city String?

  createdAt DateTime @default(now())

  fees CompetitorFee[]
}

model CompetitorFee {
  id String @id @default(cuid())

  competitorSchoolId String

  grade String

  monthlyFeeCents Int

  createdAt DateTime @default(now())

  competitorSchool CompetitorSchool @relation(fields: [competitorSchoolId], references: [id])

  @@index([competitorSchoolId])
  @@index([grade])
}

model LetterTemplate {
  id String @id @default(cuid())

  schoolId String

  type LetterType

  name String

  subject String

  body String

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  school School @relation(fields: [schoolId], references: [id])

  @@index([schoolId, type])
}

model Letter {
  id String @id @default(cuid())

  schoolId String

  type LetterType

  status LetterStatus @default(DRAFT)

  parentId String

  learnerId String?

  amountCents Int?

  dueDate DateTime?

  subject String

  body String

  createdAt DateTime @default(now())

  sentAt DateTime?

  school School @relation(fields: [schoolId], references: [id])

  parent Parent @relation(fields: [parentId], references: [id])

  learner Learner? @relation(fields: [learnerId], references: [id])

  @@index([schoolId, type])
  @@index([parentId])
}
model TeacherPerformance {

  id                   String   @id @default(cuid())

  schoolId             String

  teacherName          String

  teacherEmail         String?

  month                String

  learnerResults       Float

  classroomManagement  Float

  teachingQuality      Float

  administration       Float

  professionalConduct  Float

  finalScore           Float

  performanceLevel     String

  notes                String?

  createdAt            DateTime @default(now())

  updatedAt            DateTime @updatedAt



  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)



  @@index([schoolId])

  @@index([month])

}
