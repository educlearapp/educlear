  sendingAt              DateTime?
  sentAt                 DateTime?
  failedAt               DateTime?
  error                  String?                    @db.Text
  providerResponse       Json?
  createdBy              String                     @default("")
  retryCount             Int                        @default(0)
  parentNotificationId   String?

  school               School                 @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  campaign             CommunicationCampaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  parent               Parent?                @relation(fields: [parentId], references: [id], onDelete: SetNull)
  learner              Learner?               @relation(fields: [learnerId], references: [id], onDelete: SetNull)
  parentNotification   ParentNotification?    @relation("ParentNotificationEngineMessages", fields: [parentNotificationId], references: [id], onDelete: SetNull)
  recipients           CommunicationRecipient[]
  logs                 CommunicationLog[]

  @@index([schoolId, status])
  @@index([schoolId, category])
  @@index([schoolId, channel])
  @@index([queuedAt])
  @@index([parentId])
}

model CommunicationRecipient {
  id        String @id @default(cuid())
  messageId String
  role      String @default("to")
  address   String

  message CommunicationMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
}

model CommunicationLog {
  id        String   @id @default(cuid())
  schoolId  String
  messageId String
  event     String
  detail    Json?
  createdAt DateTime @default(now())

  school  School               @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  message CommunicationMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([schoolId, createdAt])
  @@index([messageId, createdAt])
}

model PushSubscription {
  id        String   @id @default(cuid())
  schoolId  String
  parentId  String
  endpoint  String   @unique
  keys      Json?
  userAgent String?
  createdAt DateTime @default(now())

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  parent Parent @relation(fields: [parentId], references: [id], onDelete: Cascade)

  @@index([schoolId, parentId])
}