generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"

  url = env("DATABASE_URL")
}

enum FeeFrequency {
  MONTHLY

  MONTHLY_EXCL_DEC

  MONTHLY_EXCL_NOV_DEC

  ONCE_OFF

  ANNUALLY

  YEARLY

  TERMLY

  DAILY
}

enum FeeCategory {
  SCHOOL_CHARGE
  EXTRAMURAL_CHARGE
}

enum UserRole {
  SCHOOL_ADMIN

  FINANCE

  STAFF
}

model School {
  id String @id @default(cuid())

  name String

  email String? @unique

  phone String?

  /// Physical / postal address for correspondence and payslips.
  address String?

  /// Optional logo image URL for payslips and branding (HTTPS recommended).
  logoUrl String?

  /// Optional brand color for PDFs and UI (e.g. #1a2b3c or #36a).
  primaryColor String?

  createdAt DateTime @default(now())

  users User[]
  roles SchoolRole[]

  parents Parent[]

  learners         Learner[]
  familyAccounts   FamilyAccount[]
  fees             FeeStructure[]
  SchoolFeeSetting SchoolFeeSetting[]
  LetterTemplate   LetterTemplate[]
  Letter           Letter[]

  teacherPerformances TeacherPerformance[]
  employees           Employee[]

  payrollSettings PayrollSetting[]

  payrollRuns PayrollRun[]

  payslips Payslip[]

  payrollEmailLogs PayrollEmailLog[]
  InvoiceRun       InvoiceRun[]
  Invoice          Invoice[]

  payments Payment[]

  lateFineRuns     LateFineRun[]
  lateFineRunItems LateFineRunItem[]

  learnerBillingPlans     LearnerBillingPlan[]
  learnerBillingPlanItems LearnerBillingPlanItem[]

  homeworks      Homework[]
  projects       Project[]
  notices        Notice[]
  tuckshopMenus  TuckshopMenu[]
  messageThreads MessageThread[]

  emailSettings SchoolEmailSettings?
}

model SchoolEmailSettings {
  id String @id @default(cuid())

  schoolId String @unique

  provider String?

  smtpHost String
  smtpPort Int @default(587)
  smtpSecure Boolean @default(false)

  smtpUser String
  smtpPass String

  smtpFrom String?
  replyTo String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
}

model FeeStructure {
  id String @id @default(cuid())

  schoolId String

  /// Legacy fields (kept for existing billing UI compatibility)
  name String

  amount Float

  frequency FeeFrequency

  /// Fees module fields
  category    FeeCategory?
  type        String?
  description String?

  notes String?

  grade String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  isActive Boolean @default(true)

  school School @relation(fields: [schoolId], references: [id])

  billingPlanItems LearnerBillingPlanItem[]

  @@index([schoolId])
  @@index([schoolId, isActive])
}

model User {
  id String @id @default(cuid())

  schoolId String

  email String

  passwordHash String

  isActive Boolean @default(true)

  /// RBAC role assignment (preferred). Kept optional for backward compatibility.
  roleId String?

  role UserRole @default(SCHOOL_ADMIN)

  createdAt DateTime @default(now())

  school School @relation(fields: [schoolId], references: [id])

  roleRef SchoolRole? @relation(fields: [roleId], references: [id], onDelete: SetNull)

  permissionOverrides UserPermissionOverride[]

  messageThreadsAsTeacher MessageThread[] @relation("TeacherMessageThreads")

  @@unique([schoolId, email])
  @@index([schoolId])
  @@index([roleId])
}

/// Global permission catalog (keys are stable across schools)
model Permission {
  id String @id @default(cuid())

  key String @unique

  label String

  description String?

  category String?

  rolePermissions RolePermission[]
  userOverrides   UserPermissionOverride[]
}

/// Role definitions are per-school
model SchoolRole {
  id String @id @default(cuid())

  schoolId String

  name String

  /// Owner role effectively implies all permissions.
  isOwner Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school      School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  users       User[]
  permissions RolePermission[]

  @@unique([schoolId, name])
  @@index([schoolId])
}

model RolePermission {
  id String @id @default(cuid())

  roleId       String
  permissionId String

  role       SchoolRole @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

/// Optional per-user overrides (allow/deny). When present, overrides role permissions.
model UserPermissionOverride {
  id String @id @default(cuid())

  userId       String
  permissionId String

  allowed Boolean

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionId])
  @@index([userId])
  @@index([permissionId])
}

model Parent {
  id String @id @default(cuid())

  schoolId        String
  familyAccountId String?

  relationship String?

  title String?

  firstName String

  surname String

  nickname String?

  idNumber String? @unique
  status   String  @default("GREEN")

  outstandingAmount Float @default(0)

  maritalStatus String?

  notes String?

  homeNo String?

  workNo String?

  cellNo String

  faxNo String?

  email String?

  communicationByEmail Boolean @default(true)

  communicationByPrint Boolean @default(true)

  communicationBySMS Boolean @default(true)

  createdAt DateTime @default(now())

  school        School         @relation(fields: [schoolId], references: [id])
  familyAccount FamilyAccount? @relation(fields: [familyAccountId], references: [id])

  links ParentLearnerLink[]

  Letter   Letter[]
  invoices Invoice[]
  payments Payment[]

  lateFineRunItems LateFineRunItem[]

  parentUser     ParentUser?
  messageThreads MessageThread[]

  @@index([schoolId])
  @@index([schoolId, cellNo])
}

model Payment {
  id String @id @default(cuid())

  schoolId String
  parentId String

  amount Float
  method String?

  createdAt DateTime @default(now())

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  parent Parent @relation(fields: [parentId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([parentId])
  @@index([createdAt])
}

model FamilyAccount {
  id String @id @default(cuid())

  schoolId String

  accountRef String @unique

  familyName String

  createdAt DateTime @default(now())

  school School @relation(fields: [schoolId], references: [id])

  learners Learner[]

  parents  Parent[]
  invoices Invoice[]

  lateFineRunItems LateFineRunItem[]

  @@index([schoolId])
  @@index([schoolId, familyName])
}

model Learner {
  id String @id @default(cuid())

  schoolId        String
  familyAccountId String?
  firstName       String

  lastName String

  birthDate DateTime?
  gender    String?
  idNumber  String?

  grade String

  className String?

  admissionNo String?
  tuitionFee  Float   @default(0)

  transportFee Float @default(0)

  otherFee Float @default(0)

  totalFee Float @default(0)

  createdAt DateTime @default(now())

  school        School              @relation(fields: [schoolId], references: [id])
  familyAccount FamilyAccount?      @relation(fields: [familyAccountId], references: [id])
  links         ParentLearnerLink[]

  Letter   Letter[]
  invoices Invoice[]

  billingPlan LearnerBillingPlan?

  messageThreads MessageThread[]

  @@unique([schoolId, admissionNo])
  @@index([schoolId])
  @@index([schoolId, grade])
}

// =========================
// BILLING PLANS (Kid-e-Sys style)
// =========================

model LearnerBillingPlan {
  id String @id @default(cuid())

  schoolId  String
  learnerId String @unique

  excludeFromInvoiceRun Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school  School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  learner Learner @relation(fields: [learnerId], references: [id], onDelete: Cascade)

  items LearnerBillingPlanItem[]

  @@unique([schoolId, learnerId])
  @@index([schoolId])
  @@index([learnerId])
}

model LearnerBillingPlanItem {
  id String @id @default(cuid())

  schoolId       String
  billingPlanId  String
  feeStructureId String

  // Snapshotted fields for stable invoices and historical reporting.
  description String
  type        String?

  /// Stored as integer cents to avoid float drift.
  amountCents Int

  /// Optional due date for this specific fee line (used for overdue logic).
  dueDate DateTime?

  sortOrder Int @default(0)

  createdAt DateTime @default(now())

  school       School             @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  billingPlan  LearnerBillingPlan @relation(fields: [billingPlanId], references: [id], onDelete: Cascade)
  feeStructure FeeStructure       @relation(fields: [feeStructureId], references: [id], onDelete: Restrict)

  @@unique([billingPlanId, feeStructureId])
  @@index([schoolId])
  @@index([billingPlanId])
  @@index([feeStructureId])
}

model ParentLearnerLink {
  id String @id @default(cuid())

  schoolId String

  parentId String

  learnerId String

  relation String?

  isPrimary Boolean @default(true)

  parent Parent @relation(fields: [parentId], references: [id])

  learner Learner @relation(fields: [learnerId], references: [id])

  @@unique([parentId, learnerId])
  @@index([schoolId])
}

enum LetterType {
  DEMAND

  SECTION_41
}

enum LetterStatus {
  DRAFT

  GENERATED

  SENT
}

model SchoolFeeSetting {
  id String @id @default(cuid())

  schoolId String

  grade String

  monthlyFeeCents Int

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  school School @relation(fields: [schoolId], references: [id])

  @@unique([schoolId, grade])
  @@index([schoolId])
}

model CompetitorSchool {
  id String @id @default(cuid())

  name String

  province String?

  city String?

  createdAt DateTime @default(now())

  fees CompetitorFee[]
}

model CompetitorFee {
  id String @id @default(cuid())

  competitorSchoolId String

  grade String

  monthlyFeeCents Int

  createdAt DateTime @default(now())

  competitorSchool CompetitorSchool @relation(fields: [competitorSchoolId], references: [id])

  @@index([competitorSchoolId])
  @@index([grade])
}

model LetterTemplate {
  id String @id @default(cuid())

  schoolId String

  type LetterType

  name String

  subject String

  body String

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  school School @relation(fields: [schoolId], references: [id])

  @@index([schoolId, type])
}

model Letter {
  id String @id @default(cuid())

  schoolId String

  type LetterType

  status LetterStatus @default(DRAFT)

  parentId String

  learnerId String?

  amountCents Int?

  dueDate DateTime?

  subject String

  body String

  createdAt DateTime @default(now())

  sentAt DateTime?

  school School @relation(fields: [schoolId], references: [id])

  parent Parent @relation(fields: [parentId], references: [id])

  learner Learner? @relation(fields: [learnerId], references: [id])

  @@index([schoolId, type])
  @@index([parentId])
}

// =========================
// INVOICES (INVOICE RUN WIZARD)
// =========================

model InvoiceRun {
  id String @id @default(cuid())

  schoolId String

  description String?

  invoiceDate DateTime
  dueDate     DateTime

  /// "2026-04" (YYYY-MM) for grouping/reporting
  invoiceMonth String

  message String?

  createdAt DateTime @default(now())

  school   School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  invoices Invoice[]

  lateFineRuns LateFineRun[]

  @@index([schoolId])
  @@index([schoolId, invoiceMonth])
  @@index([createdAt])
}

model Invoice {
  id String @id @default(cuid())

  schoolId     String
  invoiceRunId String

  parentId        String
  familyAccountId String?
  learnerId       String?

  /// Denormalized snapshot for fast preview/prints.
  accountRef String?

  invoiceDate DateTime
  dueDate     DateTime

  amountCents Int

  createdAt DateTime @default(now())

  school     School     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  invoiceRun InvoiceRun @relation(fields: [invoiceRunId], references: [id], onDelete: Cascade)

  parent        Parent         @relation(fields: [parentId], references: [id], onDelete: Restrict)
  learner       Learner?       @relation(fields: [learnerId], references: [id], onDelete: SetNull)
  familyAccount FamilyAccount? @relation(fields: [familyAccountId], references: [id], onDelete: SetNull)

  lines InvoiceLine[]

  lateFineRunItems LateFineRunItem[]

  @@index([schoolId])
  @@index([invoiceRunId])
  @@index([parentId])
  @@index([familyAccountId])
  @@index([learnerId])
  @@index([createdAt])
}

model InvoiceLine {
  id String @id @default(cuid())

  invoiceId String

  description String
  amountCents Int
  /// Optional per-line due date (falls back to invoice.dueDate when null).
  dueDate DateTime?
  sortOrder   Int    @default(0)

  createdAt DateTime @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

// =========================
// LATE PAYMENT FINES
// =========================

model LateFineRun {
  id String @id @default(cuid())

  schoolId     String
  invoiceRunId String

  /// Idempotency key for this run (prevents duplicates)
  uniqueKey String

  description String  @default("Late payment fine")
  note        String?

  invoiceDate DateTime

  /// Stored as integer cents to avoid float drift.
  fineAmountCents Int

  createdAt DateTime @default(now())

  school     School     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  invoiceRun InvoiceRun @relation(fields: [invoiceRunId], references: [id], onDelete: Cascade)

  items LateFineRunItem[]

  @@unique([schoolId, uniqueKey])
  @@index([schoolId])
  @@index([invoiceRunId])
  @@index([createdAt])
}

model LateFineRunItem {
  id String @id @default(cuid())

  schoolId      String
  lateFineRunId String

  parentId        String
  familyAccountId String?

  invoiceId     String
  invoiceLineId String

  /// Amount charged for this specific account.
  amountCents Int

  /// Snapshot balances for audit/debug.
  previousOutstandingAmount Float
  newOutstandingAmount      Float

  createdAt DateTime @default(now())

  school School      @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  run    LateFineRun @relation(fields: [lateFineRunId], references: [id], onDelete: Cascade)

  parent        Parent         @relation(fields: [parentId], references: [id], onDelete: Restrict)
  familyAccount FamilyAccount? @relation(fields: [familyAccountId], references: [id], onDelete: SetNull)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@unique([lateFineRunId, parentId])
  @@index([schoolId])
  @@index([lateFineRunId])
  @@index([parentId])
  @@index([invoiceId])
  @@index([createdAt])
}

// =========================
// BILLING DOCUMENT RUNS (Legal letters)
// =========================

model BillingDocumentRun {
  id String @id @default(cuid())

  schoolId String

  /// e.g. LETTER_OF_DEMAND, SECTION_41_NOTICE, FINAL_LETTER_OF_DEMAND
  documentType String

  letterDate   DateTime
  deadlineDate DateTime
  note         String?

  createdAt DateTime @default(now())

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  items  BillingDocumentRunItem[]

  @@index([schoolId])
  @@index([schoolId, createdAt])
}

model BillingDocumentRunItem {
  id String @id @default(cuid())

  runId   String
  schoolId String

  parentId  String?
  learnerId String?
  accountId String?

  parentEmail String?

  totalOutstandingBalance Decimal @db.Decimal(12, 2)
  overdueBalance          Decimal @db.Decimal(12, 2)

  generatedHtml String?

  /// NOT_SENT | SENT | FAILED
  emailStatus String @default("NOT_SENT")
  sentAt      DateTime?

  createdAt DateTime @default(now())

  run BillingDocumentRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  parent Parent? @relation(fields: [parentId], references: [id], onDelete: SetNull)
  learner Learner? @relation(fields: [learnerId], references: [id], onDelete: SetNull)
  familyAccount FamilyAccount? @relation(fields: [accountId], references: [id], onDelete: SetNull)

  @@index([runId])
  @@index([schoolId])
  @@index([schoolId, emailStatus])
  @@index([parentId])
  @@index([accountId])
}

model TeacherPerformance {
  id String @id @default(cuid())

  schoolId String

  teacherName String

  teacherEmail String?

  month String

  learnerResults Float

  classroomManagement Float

  teachingQuality Float

  administration Float

  professionalConduct Float

  finalScore Float

  performanceLevel String

  notes String?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([month])
}

// =========================

// PAYROLL ENUMS

// =========================

enum EmploymentType {
  PERMANENT

  TEMPORARY

  CONTRACT

  PART_TIME

  CASUAL
}

enum SalaryType {
  MONTHLY

  WEEKLY

  DAILY

  HOURLY
}

enum PayFrequency {
  MONTHLY

  WEEKLY

  FORTNIGHTLY
}

enum PayrollRunStatus {
  DRAFT

  FINALIZED

  CANCELLED
}

enum PayrollItemType {
  EARNING

  DEDUCTION

  EMPLOYER_CONTRIBUTION
}

enum PayrollItemCode {
  BASIC_SALARY

  OVERTIME

  BONUS

  COMMISSION

  ALLOWANCE

  HOUSING_ALLOWANCE

  TRANSPORT_ALLOWANCE

  CELLPHONE_ALLOWANCE

  OTHER_EARNING

  PAYE

  UIF_EMPLOYEE

  PENSION

  MEDICAL_AID

  STAFF_LOAN

  STAFF_ADVANCE

  UNION_FEE

  OTHER_DEDUCTION

  UIF_EMPLOYER

  OTHER_EMPLOYER_CONTRIBUTION
}

enum PayslipDeliveryPreference {
  PRINT

  EMAIL

  BOTH
}

enum PayslipEmailStatus {
  NOT_SENT

  SENT

  FAILED
}

enum PayslipPrintStatus {
  NOT_PRINTED

  PRINTED
}

enum PayrollReportType {
  SALARY_REGISTER

  DEDUCTION_REGISTER

  EMPLOYER_CONTRIBUTION

  PAYROLL_SUMMARY

  PAYROLL_PACK
}

// =========================

// PAYROLL MODELS

// =========================

model Employee {
  id String @id @default(cuid())

  schoolId String

  employeeNumber String?

  firstName String

  lastName String

  fullName String?

  idNumber String?

  dateOfBirth DateTime?

  gender String?

  mobileNumber String?

  email String?

  physicalAddress String? @db.Text

  jobTitle String?

  department String?

  employmentType EmploymentType @default(PERMANENT)

  salaryType SalaryType @default(MONTHLY)

  payFrequency PayFrequency @default(MONTHLY)

  paymentMethod String?

  startDate DateTime?

  endDate DateTime?

  isActive Boolean @default(true)

  taxNumber String?

  uifApplicable Boolean @default(true)

  incomeTaxApplicable Boolean @default(true)

  basicSalary Decimal @default(0) @db.Decimal(12, 2)

  hourlyRate Decimal @default(0) @db.Decimal(12, 2)

  overtimeRate Decimal @default(0) @db.Decimal(12, 2)

  overtimeHours Decimal @default(0) @db.Decimal(12, 2)

  fixedHousingAllowance Decimal @default(0) @db.Decimal(12, 2)

  fixedTransportAllowance Decimal @default(0) @db.Decimal(12, 2)

  fixedCellphoneAllowance Decimal @default(0) @db.Decimal(12, 2)

  fixedOtherAllowance Decimal @default(0) @db.Decimal(12, 2)

  fixedPension Decimal @default(0) @db.Decimal(12, 2)

  fixedMedicalAid Decimal @default(0) @db.Decimal(12, 2)

  fixedStaffLoan Decimal @default(0) @db.Decimal(12, 2)

  fixedStaffAdvance Decimal @default(0) @db.Decimal(12, 2)

  fixedOtherDeduction Decimal @default(0) @db.Decimal(12, 2)

  employeeMedicalAid Decimal @default(0) @db.Decimal(12, 2)

  employerMedicalAid Decimal @default(0) @db.Decimal(12, 2)

  employeePension Decimal @default(0) @db.Decimal(12, 2)

  employerPension Decimal @default(0) @db.Decimal(12, 2)

  bankAccountHolder String?

  bankName String?

  bankAccountNumber String?

  bankBranchCode String?

  payslipDeliveryPreference PayslipDeliveryPreference @default(BOTH)

  sendPayslipByEmail Boolean @default(true)

  notes String? @db.Text

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  payrollRunEmployees PayrollRunEmployee[]

  payslips Payslip[]

  @@index([schoolId])
  @@index([employeeNumber])
  @@index([email])
  @@index([isActive])
}

model PayrollSetting {
  id String @id @default(cuid())

  schoolId String

  taxYear Int

  isActive Boolean @default(true)

  payFrequency PayFrequency @default(MONTHLY)

  defaultPayDay Int?

  currency String @default("ZAR")

  // SARS / UIF settings

  primaryRebate Decimal @default(0) @db.Decimal(12, 2)

  secondaryRebate Decimal @default(0) @db.Decimal(12, 2)

  tertiaryRebate Decimal @default(0) @db.Decimal(12, 2)

  taxThresholdUnder65 Decimal @default(0) @db.Decimal(12, 2)

  taxThreshold65To74 Decimal @default(0) @db.Decimal(12, 2)

  taxThreshold75AndOver Decimal @default(0) @db.Decimal(12, 2)

  uifEnabled Boolean @default(true)

  uifEmployeePercent Decimal @default(1) @db.Decimal(5, 2)

  uifEmployerPercent Decimal @default(1) @db.Decimal(5, 2)

  uifMonthlyCeiling Decimal @default(17712) @db.Decimal(12, 2)

  payslipPrefix String? @default("PS")

  payrollRunPrefix String? @default("PR")

  payrollEmailFromName String?

  payrollEmailReplyTo String?

  payslipEmailSubjectTemplate String? @db.Text

  payslipEmailBodyTemplate String? @db.Text

  bookkeeperName String?

  bookkeeperEmail String?

  bookkeeperSendPdf Boolean @default(true)

  bookkeeperSendExcel Boolean @default(true)

  bookkeeperEmailSubjectTemplate String? @db.Text

  bookkeeperEmailBodyTemplate String? @db.Text

  envelopeTopOffsetMm Decimal @default(0) @db.Decimal(8, 2)

  envelopeLeftOffsetMm Decimal @default(0) @db.Decimal(8, 2)

  showFoldGuide Boolean @default(false)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  payrollRuns PayrollRun[]

  @@unique([schoolId, taxYear])
  @@index([schoolId])
  @@index([taxYear])
}

model PayrollRun {
  id String @id @default(cuid())

  schoolId String

  payrollSettingId String?

  runNumber String?

  taxYear Int

  payrollMonth Int

  payrollYear Int

  payDate DateTime

  status PayrollRunStatus @default(DRAFT)

  employeeCount Int @default(0)

  grossTotal Decimal @default(0) @db.Decimal(14, 2)

  deductionsTotal Decimal @default(0) @db.Decimal(14, 2)

  netTotal Decimal @default(0) @db.Decimal(14, 2)

  employerCostTotal Decimal @default(0) @db.Decimal(14, 2)

  finalizedAt DateTime?

  notes String? @db.Text

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  payrollSetting PayrollSetting? @relation(fields: [payrollSettingId], references: [id], onDelete: SetNull)

  employees PayrollRunEmployee[]

  payslips Payslip[]

  emailLogs PayrollEmailLog[]

  @@index([schoolId])
  @@index([payrollSettingId])
  @@index([taxYear, payrollMonth, payrollYear])
  @@index([status])
}

model PayrollRunEmployee {
  id String @id @default(cuid())

  payrollRunId String

  employeeId String

  basicSalary Decimal @default(0) @db.Decimal(12, 2)

  overtimeAmount Decimal @default(0) @db.Decimal(12, 2)

  bonusAmount Decimal @default(0) @db.Decimal(12, 2)

  allowanceAmount Decimal @default(0) @db.Decimal(12, 2)

  otherEarningsAmount Decimal @default(0) @db.Decimal(12, 2)

  grossPay Decimal @default(0) @db.Decimal(12, 2)

  payeAmount Decimal @default(0) @db.Decimal(12, 2)

  uifEmployeeAmount Decimal @default(0) @db.Decimal(12, 2)

  otherDeductionsAmount Decimal @default(0) @db.Decimal(12, 2)

  totalDeductions Decimal @default(0) @db.Decimal(12, 2)

  netPay Decimal @default(0) @db.Decimal(12, 2)

  uifEmployerAmount Decimal @default(0) @db.Decimal(12, 2)

  employerCost Decimal @default(0) @db.Decimal(12, 2)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  payrollRun PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  items PayrollItem[]

  payslip Payslip?

  @@unique([payrollRunId, employeeId])
  @@index([payrollRunId])
  @@index([employeeId])
}

model PayrollItem {
  id String @id @default(cuid())

  payrollRunEmployeeId String

  itemType PayrollItemType

  itemCode PayrollItemCode

  label String

  amount Decimal @default(0) @db.Decimal(12, 2)

  taxable Boolean @default(true)

  sortOrder Int @default(0)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  payrollRunEmployee PayrollRunEmployee @relation(fields: [payrollRunEmployeeId], references: [id], onDelete: Cascade)

  @@index([payrollRunEmployeeId])
  @@index([itemType])
  @@index([itemCode])
}

model Payslip {
  id String @id @default(cuid())

  schoolId String

  payrollRunId String

  payrollRunEmployeeId String @unique

  employeeId String

  payslipNumber String?

  taxYear Int

  payrollMonth Int

  payrollYear Int

  payDate DateTime

  grossPay Decimal @default(0) @db.Decimal(12, 2)

  totalDeductions Decimal @default(0) @db.Decimal(12, 2)

  netPay Decimal @default(0) @db.Decimal(12, 2)

  employerCost Decimal @default(0) @db.Decimal(12, 2)

  pdfPath String?

  emailStatus PayslipEmailStatus @default(NOT_SENT)

  printStatus PayslipPrintStatus @default(NOT_PRINTED)

  emailedAt DateTime?

  emailedTo String?

  printedAt DateTime?

  lastEmailError String? @db.Text

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  payrollRun PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)

  payrollRunEmployee PayrollRunEmployee @relation(fields: [payrollRunEmployeeId], references: [id], onDelete: Cascade)

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([payrollRunId])
  @@index([employeeId])
  @@index([emailStatus])
}

model PayrollEmailLog {
  id String @id @default(cuid())

  schoolId String

  payrollRunId String?

  reportType PayrollReportType?

  recipientName String?

  recipientEmail String

  subject String?

  body String? @db.Text

  success Boolean @default(false)

  errorMessage String? @db.Text

  attachedPdf Boolean @default(false)

  attachedExcel Boolean @default(false)

  createdAt DateTime @default(now())

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  payrollRun PayrollRun? @relation(fields: [payrollRunId], references: [id], onDelete: SetNull)

  @@index([schoolId])
  @@index([payrollRunId])
  @@index([recipientEmail])
  @@index([createdAt])
}

model ParentUser {
  id String @id @default(cuid())

  parentId String @unique
  email    String @unique
  password String

  createdAt DateTime @default(now())

  parent Parent @relation(fields: [parentId], references: [id], onDelete: Cascade)

  @@index([parentId])
}

model Homework {
  id String @id @default(cuid())

  schoolId    String
  className   String
  subject     String?
  title       String
  description String?
  dueDate     DateTime
  createdAt   DateTime @default(now())

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([schoolId, className])
  @@index([dueDate])
  @@index([createdAt])
}

model Project {
  id String @id @default(cuid())

  schoolId    String
  className   String
  subject     String?
  title       String
  description String?
  dueDate     DateTime
  createdAt   DateTime @default(now())

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([schoolId, className])
  @@index([dueDate])
  @@index([createdAt])
}

model Notice {
  id String @id @default(cuid())

  schoolId  String
  title     String
  message   String
  date      DateTime
  createdAt DateTime @default(now())

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([date])
  @@index([createdAt])
}

model TuckshopMenu {
  id String @id @default(cuid())

  schoolId  String
  date      DateTime
  items     Json
  createdAt DateTime @default(now())

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, date])
  @@index([schoolId])
  @@index([date])
  @@index([createdAt])
}

model MessageThread {
  id String @id @default(cuid())

  schoolId  String
  learnerId String
  parentId  String
  teacherId String?

  topic     String
  status    String   @default("OPEN")
  createdAt DateTime @default(now())

  school  School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  learner Learner @relation(fields: [learnerId], references: [id], onDelete: Cascade)
  parent  Parent  @relation(fields: [parentId], references: [id], onDelete: Cascade)
  teacher User?   @relation("TeacherMessageThreads", fields: [teacherId], references: [id], onDelete: SetNull)

  replies MessageReply[]

  @@index([schoolId])
  @@index([parentId])
  @@index([teacherId])
  @@index([learnerId])
  @@index([status])
  @@index([createdAt])
}

model MessageReply {
  id String @id @default(cuid())

  threadId   String
  senderId   String
  senderRole String
  message    String
  createdAt  DateTime @default(now())

  thread MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId])
  @@index([senderId])
  @@index([createdAt])
}
