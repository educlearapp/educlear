DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/educlear"

# Public base URL for school logo links in emails (optional; defaults to http://localhost:PORT)
PUBLIC_API_URL="http://localhost:3000"
JWT_SECRET="change-me-in-production"

# Comma-separated platform super admin emails (login + /migration access)
SUPER_ADMIN_EMAILS="info@educlear.co.za"

# One-time seed — set password locally, never commit real values
SUPER_ADMIN_SEED_EMAIL="info@educlear.co.za"
SUPER_ADMIN_SEED_PASSWORD=""

# Da Silva Academy owner (scripts/ensure-da-silva-owner.ts — only when no owner exists)
DA_SILVA_OWNER_PASSWORD=""

# School registration auth verification (scripts/verify-school-registration-auth.ts)
REGISTRATION_EMAIL=""
REGISTRATION_PASSWORD=""

# PayFast subscription checkout (sandbox: use https://sandbox.payfast.co.za in notify URL host)
PAYFAST_MERCHANT_ID=""
PAYFAST_MERCHANT_KEY=""
PAYFAST_PASSPHRASE=""
PAYFAST_RETURN_URL="http://localhost:5173/subscription/status?payment=return"
PAYFAST_CANCEL_URL="http://localhost:5173/subscription/status?payment=cancel"
PAYFAST_NOTIFY_URL="http://localhost:4000/api/payfast/notify"
